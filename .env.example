# Copy to .env and edit secrets. Do not commit .env.
# Required for: docker compose, make up

# Postgres (used by db + backend)
POSTGRES_USER=quote
POSTGRES_PASSWORD=quote
POSTGRES_DB=quote

# Backend (fill in; use host "db" when running in Docker)
DATABASE_URL=
JWT_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=
SMTP_TIMEOUT_SECONDS=20

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
